# =====================================================================
# ContractGuard configuration. Copy this file to ".env" and fill in.
#   cp .env.example .env
# The system runs WITHOUT any keys (deterministic MOCK mode). Add a key
# to switch the agents to a real LLM.
# =====================================================================

# Which LLM provider the agents use: "openai" (default) or "anthropic".
LLM_PROVIDER=openai

# --- OpenAI (default) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (optional alternative) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Force deterministic mock mode even if a key is present (great for demos/eval).
# Set to 1/true to enable.
CONTRACTGUARD_MOCK=

# Risk routing thresholds (0-100 risk score).
HIGH_RISK_THRESHOLD=60
LOW_RISK_THRESHOLD=25

# --- LangSmith tracing (optional, free tier) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=contractguard
